# Macro Alpha Pro — git ignore patterns
# Created P6 (2026-05-07). Covers: secrets, local databases, generated
# caches, RAG persistent store, model checkpoints, Python artifacts.

# ── Secrets (NEVER commit) ───────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Publish pipeline output (regenerated by build_public_snapshot.py) ────────
data/publish/

# ── Operator Console runtime data (per-install, never committed) ─────────────
data/operator_console/

# ── Databases (local state; multi-MB binary; not source of truth) ────────────
*.db
*.db-shm
# ChromaDB persistent stores — regeneratable from the source jsonl + the
# embedding model. NOT a source of truth.
data/research_store/papers_chroma/
# R4.3 — SQLite read indexes (lazy-rebuilt from jsonl; not source-of-truth)
data/research_store/_index/
# R4.2 — local usage telemetry (single-user, no PII)
data/telemetry/
*.db-wal
*.db.before_*
_dlp0_smoke.db

# ── RAG persistent store + cost tracker (P2 deliverable) ─────────────────────
.streamlit/rag_store/
.streamlit/rag_synthesis_cost.json
.streamlit/llm_cache/
.streamlit/auto_audit_llm_cost.json
.streamlit/key_pool_stats.json

# ── Cache files ──────────────────────────────────────────────────────────────
quant_flip_cache.json
scanner_daily_cache.json
scheduler.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── HuggingFace model cache (~1.1GB after first run; user-specific) ──────────
# Note: HF cache lives in user home (~/.cache/huggingface/), not in repo —
# this entry is defensive in case someone symlinks or copies it locally.
.cache/
hf_cache/

# ── Audit / temporary outputs ────────────────────────────────────────────────
audit_findings.json
tier1_audit_results.json
*.tmp
*.bak

# ── OS-specific ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# Forensic runtime cache (dynamic AV news cache, not source)
data/forensic/av_news_cache.json

# ── Sprint I D-PEAD-Plus runtime data (all .parquet files in this folder) ──
# Untracked to prevent git stash race: stash temporarily reverts working tree to
# HEAD state, but a long-running extraction process writes to these files in
# parallel. If save_extractions() reads parquet during stash window, it sees
# HEAD's stale version and silently overwrites. Untracking eliminates this race.
# (Bug observed 2026-05-13: ~3401 records lost from cache mid-extraction.)
# Generalized to ALL parquets in this folder for prevention.
data/d_pead_plus/*.parquet

# L2-1 PIT data caches (>100MB, pulled from WRDS via scripts/extend_compustat_funda_pit_history.py)
data/cache/_compustat_funda_pit*.parquet

# L2-4 prep: per-Tier-C-dispatch monthly PnL artifacts (~19KB each;
# regenerable by re-running the template; path recorded in verdict
# event metrics for L2-4/5/6 consumers to re-read locally)
data/research_store/tier_c_pnl/*.parquet

# L2-4 anchor library — Ken French FF5+MOM monthly factors
# + Ken French 12-Industry + FRED cross-asset macro anchors
# (all regenerable via scripts/fetch_anchor_library.py /
# fetch_cross_asset_macro_anchors.py)
data/anchor_library/*.parquet
